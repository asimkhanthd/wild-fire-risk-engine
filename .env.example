# Copy to .env and adjust as needed:  cp .env.example .env


# Public HAProxy port. The four STORCITO API containers listen internally on 8085.
STORCITO_HOST=0.0.0.0
STORCITO_PORT=8085
STORCITO_HAPROXY_STATS_PORT=8406
STORCITO_POSTGRES_PORT=5435

# PostGIS database credentials (shared by postgis, storcito and geotools).
POSTGRES_DB=gis
POSTGRES_USER=gis
POSTGRES_PASSWORD=gis

# Optional: external URL used to build download links returned to wildfire.
# Leave empty to infer from the inbound request.
PUBLIC_BASE_URL=
